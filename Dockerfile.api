FROM golang:1.22-alpine AS build

WORKDIR /app

COPY api/go.mod ./
COPY api/cmd ./cmd
COPY api/internal ./internal

RUN go build -o /theme-server ./cmd/server

FROM alpine:3.20

RUN adduser -D -u 10001 appuser

USER appuser
WORKDIR /app

COPY --from=build /theme-server /app/theme-server

EXPOSE 8080

CMD ["/app/theme-server"]
